{
  "name": "pi-forge",
  "version": "1.4.3",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "concurrently \"PORT=${PORT:-3100} npm run dev -w packages/server\" \"PORT=${PORT:-3100} npm run dev -w packages/client\"",
    "dev:remote": "concurrently \"HOST=${HOST:-0.0.0.0} PORT=${PORT:-3100} npm run dev -w packages/server\" \"PORT=${PORT:-3100} npm run dev -w packages/client -- --host\"",
    "typecheck": "npm run check --workspaces --if-present && tsc -p tests/tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "test": "scripts/run-tests.sh",
    "test:ci": "scripts/run-tests.sh --ci",
    "build:site": "node scripts/build-site.mjs",
    "build:publish": "node scripts/build-publish-dir.mjs"
  },
  "overrides": {
    "serialize-javascript": ">=6.0.2",
    "qs": ">=6.15.2",
    "tmp": ">=0.2.6",
    "uuid": ">=11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "concurrently": "^10.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "marked": "^18.0.5",
    "prettier": "^3.8.4",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "node-pty@1.1.0": true,
    "@google/genai": false,
    "protobufjs": false,
    "esbuild@0.28.1": true
  }
}
