{
  "name": "pi-forge",
  "version": "1.2.2",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "concurrently \"npm run dev -w packages/server\" \"npm run dev -w packages/client\"",
    "dev:remote": "HOST=0.0.0.0 concurrently \"npm run dev -w packages/server\" \"npm run dev -w packages/client -- --host\"",
    "typecheck": "npm run check --workspaces --if-present && tsc -p tests/tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "test": "scripts/run-tests.sh",
    "test:ci": "scripts/run-tests.sh --ci",
    "build:site": "node scripts/build-site.mjs",
    "build:publish": "node scripts/build-publish-dir.mjs"
  },
  "overrides": {
    "serialize-javascript": ">=6.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "concurrently": "^9.1.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.5.3",
    "marked": "^18.0.3",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
